#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONTEXT_FILE="$ROOT_DIR/.offhours.env"

if [[ -z "${OFFHOURS_TABLE_SERVICE_URI:-}" && -f "$CONTEXT_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$CONTEXT_FILE"
  set +a
fi

python3 -m offhours_cli "$@"
