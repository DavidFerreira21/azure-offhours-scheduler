      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "If true, do not stop manually started VMs outside stop window."
      }
    },
    "retainStopped": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "If true, do not start manually stopped VMs inside start window."
