    "subscriptionIds": {
      "type": "array",
      "metadata": {
        "description": "List of subscription IDs scanned by the scheduler."
      }
    },
    "schedulesFile": {
      "type": "string",
      "defaultValue": "schedules/schedules.yaml",
      "metadata": {
        "description": "Path to schedules YAML inside the app package."
      }
    },
    "dryRun": {
      "type": "bool",
      "defaultValue": false,
